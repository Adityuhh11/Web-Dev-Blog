<!DOCTYPE html>
<html lang="en">
<%- include('partials/head.partials.ejs') %>
<link rel="stylesheet" href="/styles/createblog.css">
<body>
    <section class = "create-blog-container">
        <button type="button" class="back-arrow" aria-label="Go back" onclick="window.history.back()">←</button>
        <form action="/createblog" method="POST">
            <div class="header">
                <div class="header-title">
                    <h1>Create a Blog</h1>
                </div>
            </div>

            <div class="form-group">
                <label for="title-input">title</label>
                <input id="title-input" type="text" name="title" required>
            </div>
            
            <div class="form-group">
                <label for="desc-input">description</label>
                <textarea id="desc-input" name="description" rows="4" required></textarea>
            </div>

            <div class="form-group">
                <label for="content-input">content</label>
                <!-- Include Quill stylesheet -->
                <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
                <div id="editor-container"></div>
                <input type="hidden" name="content" id="content-input">
            </div>

            <!-- Include the Quill library -->
            <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

            <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Write your blog content here...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike', 'blockquote'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'align': [] }],
                    ['link'],
                    ['clean']
                ]
            }
        });

                var form = document.querySelector('form');
                form.onsubmit = function(e) {
                    var contentInput = document.querySelector('#content-input');
                    contentInput.value = quill.root.innerHTML;
                    
                    if (quill.getText().trim().length === 0 && !quill.root.innerHTML.includes('<img')) {
                        e.preventDefault();
                        alert("Blog content cannot be empty.");
                        return false;
                    }
                };
            </script>
            <input type="hidden" name="ownerId" value="<%= user._id %>" hidden>
            
            <div class="submit-section" style="margin-top: 2rem; display: flex; justify-content: flex-end; padding: 0 2rem;">
                <button type="submit" class="primary-btn">Create Blog</button>
            </div>
        </form>
    </section>
</body>
</html>