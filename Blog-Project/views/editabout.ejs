<!DOCTYPE html>
<html lang="en">
<%- include('partials/head.partials.ejs') %>
<link rel="stylesheet" href="/styles/createblog.css">
<body>
    <section class="create-blog-container">
        <button type="button" class="back-arrow" aria-label="Go back" onclick="window.location.href='/about'">←</button>
        <form action="/edit-about" method="POST">
            <%- include('partials/csrf-field.partial.ejs') %>
            <div class="header">
                <div class="header-title">
                    <h1>Edit About Page</h1>
                </div>
            </div>

            <div class="form-group">
                <label for="title-input">title</label>
                <input id="title-input" type="text" name="title" value="<%= page.title %>" required>
            </div>
            
            <div class="form-group">
                <label for="content-input">content</label>
                <!-- Include Quill stylesheet -->
                <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
                <div id="editor-container"><%- page.content %></div>
                <input type="hidden" name="content" id="content-input">
            </div>

            <!-- Include the Quill library -->
            <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

            <script>
                var quill = new Quill('#editor-container', {
                    theme: 'snow',
                    placeholder: 'Write your about content here...',
                    modules: {
                        toolbar: [
                            [{ 'header': [1, 2, 3, false] }],
                            ['bold', 'italic', 'underline', 'strike', 'blockquote'],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            [{ 'align': [] }],
                            ['link'],
                            ['clean']
                        ]
                    }
                });

                var form = document.querySelector('form');
                form.onsubmit = function(e) {
                    var contentInput = document.querySelector('#content-input');
                    contentInput.value = quill.root.innerHTML;
                    
                    if (quill.getText().trim().length === 0 && !quill.root.innerHTML.includes('<img')) {
                        e.preventDefault();
                        alert("About content cannot be empty.");
                        return false;
                    }
                };
            </script>
            
            <div class="submit-section">
                <button type="submit" class="primary-btn">Save Changes</button>
            </div>
        </form>
    </section>
</body>
</html>
