<!DOCTYPE html>
<html lang="en">
<%- include('partials/head.partials.ejs') %>
<link rel="stylesheet" href="../styles/home.css">
<body>
    
    <section class="Title">
        <h1 class="title-text">BLOGS<span class="dot">.</span></h1>
        <div class="sub-title">
            <p>by Aditya Sai Prem</p>
        </div>
    </section>
    <div class="scroll-arrow-container">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-down" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M1.646 6.646a.5.5 0 0 1 .708 0L8 12.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/>
        <path fill-rule="evenodd" d="M1.646 2.646a.5.5 0 0 1 .708 0L8 8.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/>
        </svg>
    </div>


    <!-- Recent Blogs Section -->
    <section class="recent-blogs">
        <div class="recent-title" style="flex-shrink: 0; min-width: 400px; max-width: 500px; display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
            <p>Recent blogs</p>
            
            <!-- Newsletter Subscription Section -->
            <div style="margin-top: 10rem; padding: 2rem; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2); backdrop-filter: blur(10px);">
                <h2 style="color: white; font-family: 'IBM Plex Mono', monospace; font-size: 1.2rem; margin-bottom: 0.5rem;">Subscribe to our newsletter</h2>
                <p style="color: #888; font-family: 'Inter', sans-serif; font-size: 0.9rem; line-height: 1.5; margin-bottom: 1.5rem;">Get notified whenever a new blog is posted.</p>
                
                <form id="newsletter-form" style="display: flex; flex-direction: column; gap: 0.8rem;">
                    <input type="email" id="subscriber-email" placeholder="Enter your email address" required style="padding: 0.8rem 1rem; border-radius: 8px; border: 1px solid #333; background: #111; color: white; font-family: 'Inter', sans-serif; font-size: 0.95rem; outline: none; transition: border-color 0.3s ease;">
                    <button type="submit" style="padding: 0.8rem 1rem; border-radius: 8px; border: none; background: white; color: #040303; font-family: 'IBM Plex Mono', monospace; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.3s ease;">Subscribe</button>
                </form>
                <p id="newsletter-message" style="margin-top: 1rem; font-family: 'Inter', sans-serif; font-size: 0.85rem; min-height: 20px;"></p>
            </div>
        </div>
        <div class="recent-blog-container" id="recent-blogs-list">
            <% blogs.forEach(blog => { %>
                <div class="recent-blog" onclick="window.location.href='/post/<%= blog._id %>'">
                    <div class="recent-blog-title">
                        <h2><%= blog.title %></h2>
                    </div>
                    <div class="recent-blog-content">
                        <p><%= blog.description %></p>
                    </div>
                </div>
            <% }) %>

            <% if (blogs.length === 0) { %>
                <div class="no-blogs-message">
                    <p>No recent blogs to show. Check back later!</p>
                    <div class="view-all-button">
                        <a href="archive">View All</a>
                    </div>
                </div>
            <% } %>
        </div>
    </section>

        
    <script>
        document.getElementById('newsletter-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('subscriber-email').value;
            const messageEl = document.getElementById('newsletter-message');
            
            try {
                const response = await fetch('/subscribe', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email })
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    messageEl.textContent = "Successfully subscribed! Check your inbox for updates.";
                    messageEl.className = "newsletter-message success";
                    document.getElementById('subscriber-email').value = ""; // clear input
                } else {
                    messageEl.textContent = data.message || "Failed to subscribe. Please try again.";
                    messageEl.className = "newsletter-message error";
                }
            } catch (error) {
                messageEl.textContent = "An error occurred. Please try again.";
                messageEl.className = "newsletter-message error";
            }
        });
    </script>    <!-- Bottom Navigation -->
    <%- include('partials/navigation.partial.ejs') %>
    
</body>
</html>