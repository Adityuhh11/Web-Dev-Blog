<div id="delete-modal" class="delete-modal" hidden role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
    <div class="delete-modal-backdrop" data-delete-modal-dismiss></div>
    <div class="delete-modal-card">
        <h2 id="delete-modal-title" class="delete-modal-heading">Are you sure?</h2>
        <p id="delete-modal-message" class="delete-modal-message"></p>
        <div class="delete-modal-actions">
            <button type="button" class="delete-modal-btn delete-modal-cancel" data-delete-modal-dismiss>Cancel</button>
            <button type="button" class="delete-modal-btn delete-modal-confirm" id="delete-modal-confirm">Delete</button>
        </div>
    </div>
</div>
