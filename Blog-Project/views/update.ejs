<!DOCTYPE html>
<html lang="en">
<%- include('partials/head.partials.ejs') %>
<link rel="stylesheet" href="/styles/editor-form.css">
<link rel="stylesheet" href="/styles/update.css">
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<body class="editor-body">
    <section class="editor-page">
        <header class="editor-header">
            <% if (blog.status === 'draft') { %>
                <a href="/drafts" class="back-link" aria-label="Back to drafts">← Back</a>
                <h1>Edit Draft</h1>
                <p class="editor-subtitle">Continue writing and save your draft or publish when ready.</p>
            <% } else { %>
                <a href="/archive" class="back-link" aria-label="Back to archive">← Back</a>
                <h1>Edit Post</h1>
                <p class="editor-subtitle">Update your published post.</p>
            <% } %>
            <div class="post-meta">
                <span><%= blog.date %></span>
                <span class="post-meta-sep">·</span>
                <span><%= blog.owner.name %></span>
            </div>
        </header>

        <div class="editor-card">
            <form id="editor-form" action="/update/<%= blog._id %>" method="POST">
                <%- include('partials/csrf-field.partial.ejs') %>
                <input type="hidden" name="blogId" value="<%= blog._id %>">

                <fieldset class="form-section">
                    <legend>Post details</legend>

                    <div class="field-group">
                        <label for="title-input">Title</label>
                        <input type="text" id="title-input" name="title" value="<%= blog.title %>" placeholder="Give your post a title">
                    </div>

                    <div class="field-group">
                        <label for="description-input">Description</label>
                        <textarea name="description" id="description-input" rows="3" placeholder="A short summary shown in the archive"><%= blog.description %></textarea>
                        <p class="field-hint">This appears on the home page and archive listing.</p>
                    </div>
                </fieldset>

                <fieldset class="form-section">
                    <legend>Content</legend>
                    <div id="editor-container"><%- blog.content %></div>
                    <input type="hidden" name="content" id="content-input">
                </fieldset>
            </form>
        </div>

        <div class="editor-actions">
            <% if (blog.status === 'draft') { %>
                <p class="publish-hint">Publishing requires title, description, and content.</p>
                <div class="action-buttons">
                    <button type="submit" form="editor-form" name="status" value="draft" class="secondary-btn">Save Draft</button>
                    <button type="submit" form="editor-form" name="status" value="published" class="primary-btn">Publish</button>
                </div>
            <% } else { %>
                <p class="publish-hint">Changes are saved immediately to the live post.</p>
                <div class="action-buttons">
                    <button type="submit" form="editor-form" class="primary-btn">Update Blog</button>
                </div>
            <% } %>
        </div>
    </section>

    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Write your blog content here...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike', 'blockquote'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'align': [] }],
                    ['link'],
                    ['clean']
                ]
            }
        });

        var isDraft = <%= blog.status === 'draft' ? 'true' : 'false' %>;

        document.getElementById('editor-form').onsubmit = function(e) {
            document.getElementById('content-input').value = quill.root.innerHTML;

            var isPublishing = !isDraft || (document.activeElement?.name === 'status' && document.activeElement?.value === 'published');
            if (isPublishing && quill.getText().trim().length === 0 && !quill.root.innerHTML.includes('<img')) {
                e.preventDefault();
                alert("Blog content cannot be empty.");
                return false;
            }
        };
    </script>
</body>
</html>
